# E2B Code Sandbox
# Get your API key at https://e2b.dev — new accounts receive $100 free credit

# Your E2B API key
E2B_API_KEY=your_e2b_api_key_here

# Set to true to enable sandbox execution (false by default for safety)
SANDBOX_ENABLED=true

# Max Claude-initiated code runs per day per chat (does not apply to /run command)
SANDBOX_AUTO_RUN_DAILY_LIMIT=20
