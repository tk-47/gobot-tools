# --- URL Calendar Feed (ICS/webcal) ---
# Reads public or private calendar feeds directly from a URL.
# No API keys, OAuth, or macOS Automation required.
#
# Supports webcal:// and https:// URLs.
# You can find your feed URL in:
#   - Apple Calendar: right-click a calendar → Share → Copy Link
#   - Google Calendar: Settings → calendar → "Secret address in iCal format"
#   - Any CalDAV calendar: check your calendar app's sharing settings

# Single feed URL
APPLE_CALENDAR_URL=https://example.com/path/to/calendar.ics

# Multiple feeds (comma-separated) — all events are merged and sorted
# APPLE_CALENDAR_URLS=https://example.com/one.ics,https://example.com/two.ics

# Your timezone for formatting event times (IANA format)
# Defaults to America/Chicago if not set
USER_TIMEZONE=America/Chicago
