# Rachio Irrigation — Environment Variables

# Your Rachio API key (REQUIRED)
# Get it from: app.rach.io → Account → API Access
# Format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx (UUID)
RACHIO_API_KEY=your_rachio_api_key_here

# Webhook signing secret (optional — recommended for push notifications)
# Any strong random string — must match what you configure in Rachio's webhook settings.
# Generate one: openssl rand -hex 32
# The VPS webhook endpoint rejects requests with an invalid signature when this is set.
RACHIO_WEBHOOK_SECRET=your_webhook_secret_here

# Enable automatic rain delay when Tempest weather reports significant rainfall (optional)
# Requires TEMPEST_TOKEN to be set. Off by default.
# RACHIO_WEATHER_SYNC=false
