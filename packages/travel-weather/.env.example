# Travel Weather Alerts
# Google Maps Directions API — get key at console.cloud.google.com
# Enable "Directions API" in APIs & Services → Library
GOOGLE_MAPS_API_KEY=your_key_here

# OpenWeatherMap — get key at openweathermap.org (free tier)
# New keys can take up to 2 hours to activate
OPENWEATHERMAP_API_KEY=your_key_here
