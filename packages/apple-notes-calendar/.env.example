# Apple Notes + Calendar Integration
#
# No API keys or tokens required — this integration uses macOS Automation (JXA)
# to read directly from Notes.app and Calendar.app on your local Mac.
#
# The only requirement is a one-time Automation permission grant:
#   System Settings → Privacy & Security → Automation
#   → grant your terminal app (Terminal, iTerm2, etc.) access to Notes and Calendar
#
# Optional: set your timezone for correct event time display
USER_TIMEZONE=America/Chicago
